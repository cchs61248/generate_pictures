### 範例環境變數（請複製成 .env 後再填入真實值）
### 注意：請勿提交含真實 KEY / Cookie 的 .env

# 方案一（API Key）：用於 Gemini API
GOOGLE_API_KEY=YOUR_GOOGLE_API_KEY_HERE

# 是否只跑 stage3（0/1）
STAGE3_ONLY_MODE=0
# 切換後端方案：
# - apikey（預設，使用 GOOGLE_API_KEY）
# - webapi（使用 Cookie，不需 API Key）
# - hybrid（階段一/二 API Key，階段三 Web API 產圖）
GEMINI_BACKEND=hybrid

# 方案二（Cookie / Web API）：GEMINI_BACKEND=webapi 或 hybrid 時使用
# cookies.json：從瀏覽器匯出的 Cookie JSON 陣列（放在專案根目錄）
#
# 以下三項從瀏覽器 DevTools > Network 對 StreamGenerate 請求抓包取得（有效期短，需定期更新）：
GEMINI_AT_TOKEN=YOUR_AT_TOKEN_HERE
# 以下兩項為 StreamGenerate URL 的查詢參數（變動不頻繁）：
GEMINI_F_SID=YOUR_GEMINI_F_SID_HERE
GEMINI_REQID=YOUR_GEMINI_REQID_HERE

