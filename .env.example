### 範例環境變數（請複製成 .env 後再填入真實值）
### 注意：請勿提交含真實 KEY / Cookie 的 .env

# 方案一（API Key）：用於 Gemini API
GOOGLE_API_KEY=YOUR_GOOGLE_API_KEY_HERE

# 是否只跑 stage3（0/1）
STAGE3_ONLY_MODE=0

# 是否只使用既有圖片（0/1）
USE_EXISTING_IMAGE_ONLY=0

# 切換後端方案：
# - apikey（預設，使用 GOOGLE_API_KEY）
# - webapi（使用 Cookie，不需 API Key）
# - hybrid（階段一/二 API Key，階段三 Web API 產圖）
GEMINI_BACKEND=hybrid

# 方案二（Cookie）：GEMINI_BACKEND=webapi 時必填
# 從 https://gemini.google.com 的瀏覽器 DevTools > Network > Cookie 取得
GEMINI_COOKIE_1PSID=YOUR_1PSID_COOKIE_HERE
GEMINI_COOKIE_1PSIDTS=YOUR_1PSIDTS_COOKIE_HERE

